#!/usr/bin/env bash

source "$HOME/.config/hypr/bin/utils.sh"



action="$1"
direction="$2"

if [ "$action" == "move" ]; then
  if current_window_is_not_in_group ||
    (current_window_is_group_right && [ "$direction" == "r" ]) ||
    (current_window_is_group_left && [ "$direction" == "l" ]) ||
    [ "$direction" == "u" ] || [ "$direction" == "d" ]; then
    hyprctl dispatch "hl.dsp.window.move({ direction = '$direction', group_aware = true })"
  else
    if [ "$direction" == "l" ]; then
      hyprctl dispatch "hl.dsp.group.move_window({ forward = false })"
    else
      hyprctl dispatch "hl.dsp.group.move_window({ forward = true })"
    fi
  fi
else
  if current_workspace_has_no_window || current_window_is_not_in_group ||
    (current_window_is_group_right && [ "$direction" == "r" ]) ||
    (current_window_is_group_left && [ "$direction" == "l" ]) ||
    [ "$direction" == "u" ] || [ "$direction" == "d" ]; then
    hyprctl dispatch "hl.dsp.focus({ direction = '$direction' })"
  else
    if [ "$direction" == "l" ]; then
      direction="b"
      hyprctl dispatch "hl.dsp.group.prev()"
    else
      hyprctl dispatch "hl.dsp.group.next()"
    fi
  fi
fi
